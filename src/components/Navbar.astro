---
import type { Lang } from '../i18n/translations';
import { useTranslations, getLocalizedPath, getAlternateLang } from '../i18n/utils';
import { languages } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nero.app';
---

<nav class="fixed top-0 w-full z-50 glass border-b border-border-subtle">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
        <span class="text-white font-extrabold text-sm">N</span>
      </div>
      <span class="text-xl font-bold text-text">nero</span>
    </a>

    <!-- Center nav -->
    <div class="hidden md:flex items-center gap-8">
      <a href={getLocalizedPath('/features', lang)} class="text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navFeatures}
      </a>
      <a href={getLocalizedPath('/pricing', lang)} class="text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navPricing}
      </a>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- Language switcher -->
      <a
        href={getLocalizedPath(Astro.url.pathname.replace(`/${lang}`, '') || '/', altLang)}
        class="text-xs font-medium text-text-tertiary hover:text-text-secondary transition px-2 py-1 rounded-md hover:bg-surface-alt"
      >
        {languages[altLang]}
      </a>

      <div class="w-px h-5 bg-border-subtle hidden sm:block"></div>

      <a
        href={`https://app.${appDomain}/auth/login`}
        class="text-sm font-medium text-text-secondary hover:text-text transition hidden sm:block"
      >
        {t.navSignIn}
      </a>
      <a
        href={`https://app.${appDomain}/auth/signup`}
        class="btn btn-primary text-sm !py-2 !px-4"
      >
        {t.navGetStarted}
      </a>
    </div>
  </div>
</nav>
