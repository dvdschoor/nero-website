---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const isNl = lang === 'nl';

const integrations = [
  {
    name: 'Email',
    description: isNl ? 'Verstuur en ontvang e-mails. Automatische threading en Reply-To routing.' : 'Send and receive emails. Automatic threading and Reply-To routing.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />`,
    color: 'text-primary',
    bg: 'bg-primary/8',
  },
  {
    name: 'WhatsApp',
    description: isNl ? 'Verstuur en ontvang WhatsApp-berichten direct vanuit Nero.' : 'Send and receive WhatsApp messages directly from Nero.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />`,
    color: 'text-[#25D366]',
    bg: 'bg-[#25D366]/8',
  },
  {
    name: 'SMS',
    description: isNl ? 'Sms-berichten versturen en ontvangen via elk telefoonnummer.' : 'Send and receive SMS messages through any phone number.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />`,
    color: 'text-info',
    bg: 'bg-info/8',
  },
  {
    name: 'Slack',
    description: isNl ? 'Ontvang berichten, gebruik bot-commando\'s en laat AI je vragen beantwoorden.' : 'Receive messages, use bot commands, and let AI answer your questions.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />`,
    color: 'text-accent',
    bg: 'bg-accent/8',
  },
  {
    name: isNl ? 'Telefoon' : 'Phone',
    description: isNl ? 'Log gesprekken en laat AI notities en taken aanmaken.' : 'Log calls and let AI create notes and tasks automatically.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />`,
    color: 'text-warning',
    bg: 'bg-warning/8',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14" data-animate>
      <span class="section-label mb-4">
        {isNl ? 'Kanalen' : 'Channels'}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
        {isNl ? 'Alle kanalen, ' : 'Every channel, '}
        <span class="text-gradient">{isNl ? 'één inbox' : 'one inbox'}</span>
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        {isNl
          ? 'Verbind je bestaande communicatiekanalen in minuten. Nero brengt alles samen zodat je team vanuit één plek kan werken.'
          : 'Connect your existing communication channels in minutes. Nero brings everything together so your team works from one place.'}
      </p>
    </div>

    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
      {integrations.map((item, i) => (
        <div class="card card-hover p-5 flex flex-col items-center text-center" data-animate style={`transition-delay: ${i * 80}ms`}>
          <div class={`w-12 h-12 rounded-xl ${item.bg} ${item.color} flex items-center justify-center mb-3`}>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={item.icon} />
            </svg>
          </div>
          <h3 class="text-sm font-bold text-text">{item.name}</h3>
          <p class="mt-1 text-xs text-text-tertiary leading-relaxed">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 text-center" data-animate>
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-surface-alt border border-border-subtle text-xs text-text-tertiary">
        <svg class="w-3.5 h-3.5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        {isNl
          ? 'Versleutelde verbindingen · Geverifieerde webhooks · Volledige data-isolatie'
          : 'Encrypted connections · Verified webhooks · Full data isolation'}
      </div>
    </div>
  </div>
</section>
