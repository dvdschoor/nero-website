---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const isNl = lang === 'nl';

const stats = [
  {
    value: '5',
    label: isNl ? 'Kanalen in één inbox' : 'Channels in one inbox',
    sub: isNl ? 'Email, Slack, WhatsApp, SMS, telefoon' : 'Email, Slack, WhatsApp, SMS, phone',
  },
  {
    value: '12+',
    label: isNl ? 'AI-aangedreven modules' : 'AI-powered modules',
    sub: isNl ? 'Inbox, taken, CRM, kennis, outbound' : 'Inbox, tasks, CRM, knowledge, outbound',
  },
  {
    value: '< 2 min',
    label: isNl ? 'Setup per kanaal' : 'Setup per channel',
    sub: isNl ? 'Koppel en begin direct' : 'Connect and start immediately',
  },
  {
    value: '24/7',
    label: isNl ? 'AI-triage actief' : 'AI triage active',
    sub: isNl ? 'Procedure-gedreven, altijd aan' : 'Procedure-driven, always on',
  },
];
---

<section class="py-16 px-6 border-y border-border-subtle bg-surface">
  <div class="max-w-5xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-8">
    {stats.map((stat, i) => (
      <div class="text-center" data-animate style={`transition-delay: ${i * 100}ms`}>
        <div class="text-3xl md:text-4xl font-extrabold text-gradient">{stat.value}</div>
        <div class="mt-1 text-sm font-medium text-text">{stat.label}</div>
        <div class="mt-0.5 text-xs text-text-tertiary">{stat.sub}</div>
      </div>
    ))}
  </div>
</section>
