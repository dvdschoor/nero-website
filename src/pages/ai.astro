---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/sections/CTA.astro';
import Footer from '../components/Footer.astro';

interface FeatureBlock {
  label: string;
  title: string;
  description: string;
  bullets: string[];
  icon: string;
  accentColor: string;
}

const steps = [
  {
    number: '1',
    title: 'Message arrives',
    description: 'An email, Slack message, or WhatsApp message enters Nero through any connected channel.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />`,
  },
  {
    number: '2',
    title: 'AI applies procedures',
    description: 'Base procedures (always active) + matching topic procedures are stacked to form full context for the AI.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />`,
  },
  {
    number: '3',
    title: 'Triage output',
    description: 'Priority, category, suggested actions, and a draft reply — ready for your team to review and act on.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  },
];

const features: FeatureBlock[] = [
  {
    label: 'Procedures System',
    title: 'Your rules, the AI\'s playbook',
    description: 'Define how your business operates in markdown. Base procedures are always active, topic procedures are matched by AI category. They stack — base + matching topic = full context for every decision.',
    bullets: [
      'Base procedures always included in every AI decision',
      'Topic procedures matched automatically by message category',
      'Stacking system: base + topic = complete context',
      'Write procedures in markdown — your language, your rules',
      'AI uses procedures for triage, replies, and task creation',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
    accentColor: 'bg-info/10 text-info',
  },
  {
    label: 'AI Briefings',
    title: 'Start the day with AI intelligence',
    description: 'Every morning, Nero generates a briefing for your team. Focus areas, risk flags, and prioritized action items — based on everything that happened since the last briefing.',
    bullets: [
      'Daily briefing generated from all incoming activity',
      'Focus areas highlighted based on urgency and SLAs',
      'Risk flags for items that need immediate attention',
      'Action items prioritized and assigned to team members',
      'Briefing adapts to your procedures and business rules',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V18a2.25 2.25 0 002.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5M6 7.5h3v3H6v-3z" />`,
    accentColor: 'bg-warning/10 text-warning',
  },
  {
    label: 'Draft Replies',
    title: 'AI writes, you approve',
    description: 'For every incoming message, Nero drafts a reply tailored to the channel — email, WhatsApp, or Slack. Replies are grounded in your knowledge base and follow your procedures.',
    bullets: [
      'Channel-aware drafts: formal for email, concise for Slack',
      'Grounded in your knowledge base and procedures',
      'Respects your tone of voice and business rules',
      'One-click approve, edit, or regenerate',
      'Full audit trail of AI-generated vs. human-edited replies',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />`,
    accentColor: 'bg-success/10 text-success',
  },
  {
    label: 'Knowledge Base',
    title: 'Semantic search for your entire operation',
    description: 'Procedures, playbooks, and SLAs — all searchable by AI using semantic search. Not keyword matching, but understanding what you mean. AI also generates new articles from your daily work.',
    bullets: [
      'Semantic search: find by meaning, not just keywords',
      'AI uses knowledge base for triage, replies, and briefings',
      'Status workflow: draft, review, published',
      'AI generates new articles from daily work automatically',
      'Procedures, playbooks, and SLAs in one searchable place',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />`,
    accentColor: 'bg-primary-400/10 text-primary-400',
  },
  {
    label: 'Nero Bot',
    title: 'Your AI assistant in Slack',
    description: 'Nero Bot lives in your Slack workspace. Use slash commands to ask questions, add knowledge, create tasks, and check status — all powered by your knowledge base context.',
    bullets: [
      '/help — see available commands',
      '/ask — AI answers using your knowledge base',
      '/addknowledge — contribute knowledge from Slack',
      '/task — create tasks directly from Slack',
      '/status — check task and inbox status',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />`,
    accentColor: 'bg-accent/10 text-accent',
  },
  {
    label: 'Smart Tasks',
    title: 'Paste text, get structured tasks',
    description: 'Paste any text — an email, a meeting note, a client request — and AI creates structured tasks with subtasks, priorities, and assignments. Tasks also auto-generate from incoming messages.',
    bullets: [
      'Paste any text and AI extracts actionable tasks',
      'Subtasks automatically generated from context',
      'Priority and category assigned by AI',
      'Auto-created tasks from incoming messages',
      'Linked to source message for full traceability',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 011.65 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0118 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3l1.5 1.5 3-3.75" />`,
    accentColor: 'bg-primary/10 text-primary',
  },
  {
    label: 'Contact Matching',
    title: 'AI knows who\'s writing',
    description: 'When a message arrives, AI matches it to existing contacts in your CRM. New contacts are auto-created from email headers, so no one slips through the cracks.',
    bullets: [
      'Automatic matching of messages to existing contacts',
      'Auto-creation of new contacts from email headers',
      'Company association based on email domain',
      'Contact context available for AI triage decisions',
      'Full conversation history per contact',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />`,
    accentColor: 'bg-warning/10 text-warning',
  },
];
---

<BaseLayout title="AI Capabilities — Nero" lang="en">
  <Navbar lang="en" />
  <main>
    <!-- Hero -->
    <section class="pt-36 pb-16 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label mb-4">AI Capabilities</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-text mt-4">
          AI that <span class="text-gradient">understands your operations</span>
        </h1>
        <p class="mt-5 text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
          Nero's AI doesn't guess — it reads your procedures, searches your knowledge base, and acts within the rules you define. Every triage, reply, and task is grounded in your way of working.
        </p>
      </div>
    </section>

    <!-- How AI Triage Works -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16" data-animate>
          <span class="section-label mb-4">How AI triage works</span>
          <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
            From message to <span class="text-gradient">action</span> in seconds
          </h2>
          <p class="mt-4 text-text-secondary max-w-2xl mx-auto leading-relaxed">
            Every incoming message goes through a three-step AI pipeline that categorizes, prioritizes, and prepares a response — all based on your procedures.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {steps.map((step, i) => (
            <div class="card p-8 text-center relative" data-animate>
              {i < steps.length - 1 && (
                <div class="hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                  <svg class="w-8 h-8 text-border" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </div>
              )}
              <div class="w-12 h-12 rounded-full bg-primary/10 text-primary font-bold text-lg flex items-center justify-center mx-auto mb-5">
                {step.number}
              </div>
              <div class="w-14 h-14 rounded-2xl bg-surface-hover flex items-center justify-center mx-auto mb-5">
                <svg class="w-7 h-7 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={step.icon} />
                </svg>
              </div>
              <h3 class="text-lg font-bold text-text mb-2">{step.title}</h3>
              <p class="text-sm text-text-secondary leading-relaxed">{step.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Feature detail blocks -->
    <section class="py-24 px-6">
      <div class="max-w-5xl mx-auto space-y-20">
        {features.map((feature, i) => (
          <div class={`flex flex-col ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-12 items-center`} data-animate>
            <div class="flex-shrink-0">
              <div class={`w-20 h-20 rounded-2xl ${feature.accentColor} flex items-center justify-center`}>
                <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={feature.icon} />
                </svg>
              </div>
            </div>
            <div class="flex-1">
              <span class="section-label mb-3">{feature.label}</span>
              <h3 class="text-2xl md:text-3xl font-bold text-text mt-3">{feature.title}</h3>
              <p class="mt-3 text-text-secondary leading-relaxed">{feature.description}</p>
              <ul class="mt-5 space-y-2.5">
                {feature.bullets.map((bullet) => (
                  <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                    <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <CTA lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
