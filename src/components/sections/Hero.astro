---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nero.app';
---

<section class="relative pt-32 pb-24 px-6 overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary-100/40 rounded-full blur-3xl"></div>
    <div class="absolute top-20 right-1/4 w-[400px] h-[400px] bg-accent/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <!-- Badge -->
    <div class="section-label mb-8">
      <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
      {t.heroBadge}
    </div>

    <!-- Headline -->
    <h1 class="text-5xl md:text-6xl lg:text-7xl font-extrabold text-text leading-[1.08]">
      {t.heroTitle}<br />
      <span class="text-gradient">{t.heroTitleAccent}</span>
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
      {t.heroSubtitle}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`https://app.${appDomain}/auth/signup`} class="btn btn-primary btn-lg w-full sm:w-auto">
        {t.heroCta}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#features" class="btn btn-secondary btn-lg w-full sm:w-auto">
        {t.heroCtaSecondary}
      </a>
    </div>

    <!-- Social proof teaser -->
    <div class="mt-16 flex items-center justify-center gap-3 text-text-tertiary text-sm">
      <div class="flex -space-x-2">
        {[...Array(4)].map((_, i) => (
          <div class={`w-8 h-8 rounded-full border-2 border-bg ${
            ['bg-primary-200', 'bg-accent/20', 'bg-primary-300', 'bg-primary-100'][i]
          } flex items-center justify-center`}>
            <span class="text-xs font-semibold text-primary-800">
              {['A', 'B', 'C', 'D'][i]}
            </span>
          </div>
        ))}
      </div>
      <span>{t.socialProofTitle}</span>
    </div>
  </div>
</section>
