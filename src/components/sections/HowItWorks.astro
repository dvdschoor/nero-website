---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { title: t.howStep1Title, description: t.howStep1Desc },
  { title: t.howStep2Title, description: t.howStep2Desc },
  { title: t.howStep3Title, description: t.howStep3Desc },
];
---

<section class="py-24 px-6 bg-surface-alt/50">
  <div class="max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="section-label mb-4">{t.howItWorksLabel}</span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mt-4">
        {t.howItWorksTitle}
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-xl mx-auto">
        {t.howItWorksSubtitle}
      </p>
    </div>

    <!-- Steps -->
    <div class="space-y-6">
      {steps.map((step, i) => (
        <div class="card p-6 flex gap-5 items-start">
          <div class="step-number">{i + 1}</div>
          <div>
            <h3 class="font-bold text-text text-lg">{step.title}</h3>
            <p class="mt-1 text-text-secondary text-sm leading-relaxed">{step.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
