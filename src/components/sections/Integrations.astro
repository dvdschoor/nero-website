---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;

const isNl = lang === 'nl';

const integrations = [
  { name: 'Email', desc: isNl ? 'Ontvang en verstuur e-mails direct vanuit Nero' : 'Receive and send emails directly from Nero' },
  { name: 'Slack', desc: isNl ? 'Vang berichten op en reageer vanuit je inbox' : 'Capture messages and respond from your inbox' },
  { name: 'WhatsApp', desc: isNl ? 'Beheer klantgesprekken op WhatsApp' : 'Manage client conversations on WhatsApp' },
  { name: 'Notion', desc: isNl ? 'Importeer taken en documenten' : 'Import tasks and documents' },
  { name: 'Phone', desc: isNl ? 'Log telefoongesprekken en notities' : 'Log phone calls and notes' },
];
---

<section class="py-24 px-6 bg-surface-alt/50">
  <div class="max-w-4xl mx-auto text-center">
    <span class="section-label mb-4">
      {isNl ? 'Integraties' : 'Integrations'}
    </span>
    <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
      {isNl ? 'Verbind de tools die je al gebruikt' : 'Connect the tools you already use'}
    </h2>
    <p class="mt-4 text-lg text-text-secondary max-w-xl mx-auto">
      {isNl
        ? 'Nero brengt al je communicatiekanalen samen op een plek.'
        : 'Nero brings all your communication channels together in one place.'}
    </p>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {integrations.map((integration) => (
        <div class="card p-5 text-left hover:border-primary-200 transition">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-9 h-9 rounded-lg bg-primary-50 flex items-center justify-center">
              <span class="text-primary font-bold text-sm">{integration.name.charAt(0)}</span>
            </div>
            <h3 class="font-semibold text-text">{integration.name}</h3>
          </div>
          <p class="text-sm text-text-secondary">{integration.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
