---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;

const isNl = lang === 'nl';

const integrations = [
  {
    name: 'Email',
    desc: isNl ? 'Ontvang en verstuur e-mails direct vanuit Nero' : 'Receive and send emails directly from Nero',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />`,
    color: 'bg-info/10 text-info',
  },
  {
    name: 'Slack',
    desc: isNl ? 'Vang berichten op en reageer vanuit je inbox' : 'Capture messages and respond from your inbox',
    icon: `<path d="M14.5 2a2.5 2.5 0 00-2.5 2.5V9h4.5A2.5 2.5 0 0014.5 2zm0 0" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" /><path d="M9.5 22a2.5 2.5 0 002.5-2.5V15H7.5A2.5 2.5 0 009.5 22zm0 0M2 14.5A2.5 2.5 0 004.5 17H9v-4.5A2.5 2.5 0 002 14.5zm0 0M22 9.5A2.5 2.5 0 0019.5 7H15v4.5A2.5 2.5 0 0022 9.5z" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />`,
    color: 'bg-warning/10 text-warning',
  },
  {
    name: 'WhatsApp',
    desc: isNl ? 'Beheer klantgesprekken op WhatsApp' : 'Manage client conversations on WhatsApp',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m3.75 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 01.778-.332 48.294 48.294 0 005.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />`,
    color: 'bg-success/10 text-success',
  },
  {
    name: 'Notion',
    desc: isNl ? 'Importeer taken en documenten' : 'Import tasks and documents',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />`,
    color: 'bg-text/8 text-text',
  },
  {
    name: isNl ? 'Telefoon' : 'Phone',
    desc: isNl ? 'Log telefoongesprekken en notities' : 'Log phone calls and notes',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />`,
    color: 'bg-accent/10 text-accent',
  },
];
---

<section class="py-24 px-6 bg-surface-alt/50">
  <div class="max-w-4xl mx-auto text-center">
    <div data-animate>
      <span class="section-label mb-4">
        {isNl ? 'Integraties' : 'Integrations'}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
        {isNl ? 'Verbind de tools die je al gebruikt' : 'Connect the tools you already use'}
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-xl mx-auto">
        {isNl
          ? 'Nero brengt al je communicatiekanalen samen op een plek.'
          : 'Nero brings all your communication channels together in one place.'}
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {integrations.map((integration, i) => (
        <div class="card card-hover p-5 text-left cursor-pointer" data-animate style={`transition-delay: ${i * 80}ms`}>
          <div class="flex items-center gap-3 mb-2">
            <div class={`w-9 h-9 rounded-lg ${integration.color} flex items-center justify-center`}>
              <svg class="w-4.5 h-4.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={integration.icon} />
              </svg>
            </div>
            <h3 class="font-semibold text-text">{integration.name}</h3>
          </div>
          <p class="text-sm text-text-secondary">{integration.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
