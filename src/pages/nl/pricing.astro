---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import CTA from '../../components/sections/CTA.astro';
import FAQ from '../../components/sections/FAQ.astro';
import Footer from '../../components/Footer.astro';

const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nerops.ai';

const plans = [
  {
    name: 'Starter',
    price: 'Gratis',
    period: '',
    description: 'Voor individuen en kleine teams die beginnen.',
    features: [
      'Tot 3 teamleden',
      'Taakoperaties & uniforme inbox',
      'Contact- & bedrijfsbeheer',
      'AI-triage & prioritering (25/maand)',
      'Email-integratie',
      '1 workspace',
    ],
    cta: 'Aan de slag',
    href: `https://${appDomain}/login`,
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '\u20AC19',
    period: '/gebruiker/maand',
    description: 'Voor groeiende teams met volledige AI en multi-channel.',
    features: [
      'Tot 10 teamleden',
      'Alles in Starter',
      'AI-triage, concepten & dagbriefings (200/dag)',
      'Operationele kennisbank',
      'Deal-pipelines & forecasting',
      'Sprint planning & AI-taaksuggesties',
      'Slack, WhatsApp & SMS integraties',
      'Email support',
    ],
    cta: 'Start gratis proefperiode',
    href: `https://${appDomain}/login`,
    highlighted: true,
  },
  {
    name: 'Business',
    price: '\u20AC59',
    period: '/gebruiker/maand',
    description: 'Voor teams die AI hun operaties willen laten sturen.',
    features: [
      'Onbeperkt teamleden',
      'Alles in Pro',
      'AI-campaigns & sequences (1.000/dag)',
      'AI-gepersonaliseerde outreach per contact',
      'Custom AI-procedures & workflows',
      'Onbeperkt workspaces',
      'Prioriteit support',
    ],
    cta: 'Start gratis proefperiode',
    href: `https://${appDomain}/login`,
    highlighted: false,
  },
  {
    name: 'Enterprise',
    price: 'Op maat',
    period: '',
    description: 'Voor organisaties met geavanceerde behoeften.',
    features: [
      'Alles in Business',
      'Onbeperkte AI-operaties',
      'Maatwerk integraties',
      'SSO & geavanceerde beveiliging',
      'Toegewijd accountmanager',
      'SLA-garantie',
      'Maatwerk onboarding',
    ],
    cta: 'Neem contact op',
    href: 'mailto:hello@nerops.ai',
    highlighted: false,
  },
];
---

<BaseLayout title="Prijzen | Nero" lang="nl">
  <Navbar lang="nl" />
  <main>
    <section class="pt-36 pb-16 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label mb-4">Prijzen</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-text mt-4">
          Simpele, transparante <span class="text-gradient">prijzen</span>
        </h1>
        <p class="mt-5 text-lg text-text-secondary max-w-xl mx-auto">
          Begin gratis, upgrade wanneer je meer nodig hebt. Geen verborgen kosten, geen verrassingen.
        </p>
      </div>
    </section>

    <section class="pb-24 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {plans.map((plan) => (
          <div class={`card p-7 flex flex-col ${
            plan.highlighted
              ? 'border-primary ring-1 ring-primary/20 relative'
              : ''
          }`}>
            {plan.highlighted && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">
                  Meest populair
                </span>
              </div>
            )}

            <h3 class="text-lg font-bold text-text">{plan.name}</h3>
            <div class="mt-3 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-text">{plan.price}</span>
              {plan.period && (
                <span class="text-sm text-text-tertiary">{plan.period}</span>
              )}
            </div>
            <p class="mt-2 text-sm text-text-secondary">{plan.description}</p>

            <ul class="mt-6 space-y-3 flex-1">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                  <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={plan.href}
              class={`btn btn-lg w-full mt-8 justify-center ${
                plan.highlighted ? 'btn-primary' : 'btn-secondary'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </section>

    <FAQ lang="nl" />
    <CTA lang="nl" />
  </main>
  <Footer lang="nl" />
</BaseLayout>
