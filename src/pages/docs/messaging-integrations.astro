---
import DocsLayout from '../../layouts/DocsLayout.astro';

const sidebar = [
  {
    label: 'Getting Started',
    items: [
      { title: 'Messaging Integrations', href: '/docs/messaging-integrations' },
    ],
  },
];
---

<DocsLayout
  title="Messaging Integrations Setup Guide"
  description="Connect your workspace to send and receive WhatsApp, SMS, and Email messages directly in Nero."
  sidebar={sidebar}
  currentPath="/docs/messaging-integrations"
>
  <!-- Page header -->
  <div class="mb-8" data-animate>
    <div class="flex items-center gap-2 mb-4">
      <span class="section-label">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
        </svg>
        Integrations
      </span>
    </div>
    <h1>Messaging Integrations Setup Guide</h1>
    <p class="text-lg !text-text-secondary">
      Connect your workspace to send and receive WhatsApp, SMS, and Email messages directly in Nero.
    </p>
  </div>

  <!-- Channel overview cards -->
  <div class="grid sm:grid-cols-3 gap-4 mb-10" data-animate>
    <a href="#email-sendgrid" class="card card-hover p-5 group">
      <div class="w-10 h-10 rounded-lg bg-info/10 flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
      </div>
      <h4 class="text-sm font-semibold text-text group-hover:text-primary transition">Email</h4>
      <p class="text-xs text-text-tertiary mt-1">via SendGrid</p>
    </a>
    <a href="#whatsapp-sms-twilio" class="card card-hover p-5 group">
      <div class="w-10 h-10 rounded-lg bg-success/10 flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
        </svg>
      </div>
      <h4 class="text-sm font-semibold text-text group-hover:text-primary transition">WhatsApp</h4>
      <p class="text-xs text-text-tertiary mt-1">via Twilio</p>
    </a>
    <a href="#whatsapp-sms-twilio" class="card card-hover p-5 group">
      <div class="w-10 h-10 rounded-lg bg-warning/10 flex items-center justify-center mb-3">
        <svg class="w-5 h-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
      <h4 class="text-sm font-semibold text-text group-hover:text-primary transition">SMS</h4>
      <p class="text-xs text-text-tertiary mt-1">via Twilio</p>
    </a>
  </div>

  <!-- Table of contents -->
  <div class="card p-5 mb-10" data-animate>
    <h4 class="text-sm font-semibold text-text mb-3 flex items-center gap-2">
      <svg class="w-4 h-4 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
      </svg>
      On this page
    </h4>
    <ul class="space-y-1.5 text-sm">
      <li><a href="#email-sendgrid" class="text-text-secondary hover:text-primary transition">Email (SendGrid)</a></li>
      <li><a href="#whatsapp-sms-twilio" class="text-text-secondary hover:text-primary transition">WhatsApp & SMS (Twilio)</a></li>
      <li><a href="#faq" class="text-text-secondary hover:text-primary transition">FAQ</a></li>
    </ul>
  </div>

  <!-- ===== EMAIL (SENDGRID) ===== -->
  <section id="email-sendgrid" data-animate>
    <h2>
      <span class="inline-flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-info/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </span>
        Email (SendGrid)
      </span>
    </h2>

    <!-- Prerequisites -->
    <div class="card p-5 mb-6 border-l-3 border-l-info">
      <h4 class="text-sm font-semibold text-text mb-2 flex items-center gap-2">
        <svg class="w-4 h-4 text-info" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        What you need
      </h4>
      <ul class="space-y-1.5 text-sm text-text-secondary">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-info mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          A SendGrid account (<a href="https://signup.sendgrid.com/" target="_blank" rel="noopener">sign up free</a>)
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-info mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          A domain you own (e.g. <code>yourcompany.com</code>)
        </li>
      </ul>
    </div>

    <!-- Step 1 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">1</span>
        <h3 class="!mt-0 !mb-0">Create a SendGrid API Key</h3>
      </div>
      <ol>
        <li>Go to <strong>SendGrid Dashboard</strong> &rarr; <strong>Settings</strong> &rarr; <strong>API Keys</strong></li>
        <li>Click <strong>Create API Key</strong></li>
        <li>Name it something like <code>Nero Integration</code></li>
        <li>Select <strong>Full Access</strong> (or at minimum: Mail Send + Inbound Parse)</li>
        <li>Click <strong>Create &amp; View</strong> &mdash; copy the key immediately (you won't see it again)</li>
      </ol>
    </div>

    <!-- Step 2 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">2</span>
        <h3 class="!mt-0 !mb-0">Verify your sender email</h3>
      </div>
      <ol>
        <li>Go to <strong>Settings</strong> &rarr; <strong>Sender Authentication</strong></li>
        <li>Choose <strong>Single Sender Verification</strong> (quickest) or <strong>Domain Authentication</strong> (recommended for production)</li>
        <li>For Single Sender: enter the email you want to send from (e.g. <code>support@yourcompany.com</code>) and verify via the confirmation email</li>
        <li>For Domain Authentication: follow SendGrid's DNS instructions to add CNAME records</li>
      </ol>
    </div>

    <!-- Step 3 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">3</span>
        <h3 class="!mt-0 !mb-0">Connect in Nero</h3>
      </div>
      <ol>
        <li>Open Nero &rarr; <strong>Settings</strong> &rarr; <strong>Integrations</strong></li>
        <li>Click <strong>Connect</strong> on the SendGrid card</li>
        <li>Enter:
          <ul>
            <li><strong>API Key</strong>: paste the key from Step 1</li>
            <li><strong>Sender Email</strong>: the verified email from Step 2</li>
            <li><strong>Sender Name</strong>: how your name appears to recipients (e.g. <code>Your Company</code>)</li>
          </ul>
        </li>
        <li>Click <strong>Save</strong> &mdash; Nero validates your key automatically</li>
      </ol>
    </div>

    <!-- Step 4 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">4</span>
        <h3 class="!mt-0 !mb-0">Receive incoming emails (optional)</h3>
      </div>
      <p>To receive email replies in Nero, you need to set up SendGrid Inbound Parse:</p>

      <p><strong>1. Add a DNS MX record</strong> for your domain (or a subdomain like <code>inbound.yourcompany.com</code>):</p>
      <pre><code>Type:     MX
Host:     @ (or inbound)
Value:    mx.sendgrid.net
Priority: 10</code></pre>

      <p><strong>2. In SendGrid Dashboard</strong> &rarr; <strong>Settings</strong> &rarr; <strong>Inbound Parse</strong>:</p>
      <ul>
        <li>Click <strong>Add Host &amp; URL</strong></li>
        <li><strong>Receiving Domain</strong>: your domain (e.g. <code>yourcompany.com</code>)</li>
        <li><strong>Destination URL</strong>: <code>https://nerops.ai/api/webhooks/sendgrid</code></li>
        <li>Leave "POST the raw, full MIME message" <strong>unchecked</strong></li>
        <li>Click <strong>Add</strong></li>
      </ul>

      <p>That's it &mdash; incoming emails to your sender address will now appear in Nero conversations.</p>
    </div>

    <!-- Pricing note -->
    <div class="card p-4 mb-6 bg-surface-alt/50">
      <p class="text-sm !mb-0 flex items-start gap-2">
        <svg class="w-4 h-4 text-text-tertiary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span><strong>Pricing:</strong> SendGrid offers 100 emails/day free. Paid plans start at ~$20/month for 50,000 emails.</span>
      </p>
    </div>
  </section>

  <hr />

  <!-- ===== WHATSAPP & SMS (TWILIO) ===== -->
  <section id="whatsapp-sms-twilio" data-animate>
    <h2>
      <span class="inline-flex items-center gap-2">
        <span class="w-7 h-7 rounded-lg bg-success/10 flex items-center justify-center flex-shrink-0">
          <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
          </svg>
        </span>
        WhatsApp & SMS (Twilio)
      </span>
    </h2>

    <!-- Prerequisites -->
    <div class="card p-5 mb-6 border-l-3 border-l-success">
      <h4 class="text-sm font-semibold text-text mb-2 flex items-center gap-2">
        <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        What you need
      </h4>
      <ul class="space-y-1.5 text-sm text-text-secondary">
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          A Twilio account (<a href="https://www.twilio.com/try-twilio" target="_blank" rel="noopener">sign up free</a>)
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          A phone number (Twilio provides one, or bring your own)
        </li>
        <li class="flex items-start gap-2">
          <svg class="w-4 h-4 text-success mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          For WhatsApp: a Meta Business account linked to Twilio
        </li>
      </ul>
    </div>

    <!-- Step 1 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">1</span>
        <h3 class="!mt-0 !mb-0">Get your Twilio credentials</h3>
      </div>
      <ol>
        <li>Go to your <strong>Twilio Console</strong> (console.twilio.com)</li>
        <li>On the dashboard, find:
          <ul>
            <li><strong>Account SID</strong> (starts with <code>AC...</code>)</li>
            <li><strong>Auth Token</strong> (click to reveal)</li>
          </ul>
        </li>
        <li>Copy both values</li>
      </ol>
    </div>

    <!-- Step 2 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">2</span>
        <h3 class="!mt-0 !mb-0">Get a phone number</h3>
      </div>

      <h4>For SMS:</h4>
      <ol>
        <li>In Twilio Console &rarr; <strong>Phone Numbers</strong> &rarr; <strong>Buy a Number</strong></li>
        <li>Select a number with SMS capability</li>
        <li>Note down the number (e.g. <code>+31612345678</code>)</li>
      </ol>

      <h4>For WhatsApp:</h4>
      <ol>
        <li>Go to <strong>Twilio Console</strong> &rarr; <strong>Messaging</strong> &rarr; <strong>Try it out</strong> &rarr; <strong>Send a WhatsApp message</strong></li>
        <li>For testing, Twilio provides a sandbox number</li>
        <li>For production: connect your own WhatsApp Business number via <strong>Messaging</strong> &rarr; <strong>Senders</strong> &rarr; <strong>WhatsApp Senders</strong></li>
      </ol>
    </div>

    <!-- Step 3 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">3</span>
        <h3 class="!mt-0 !mb-0">Connect in Nero</h3>
      </div>
      <ol>
        <li>Open Nero &rarr; <strong>Settings</strong> &rarr; <strong>Integrations</strong></li>
        <li>Click <strong>Connect</strong> on the Twilio card</li>
        <li>Enter:
          <ul>
            <li><strong>Account SID</strong>: from Step 1</li>
            <li><strong>Auth Token</strong>: from Step 1</li>
            <li><strong>WhatsApp Number</strong>: your WhatsApp-enabled number (e.g. <code>+31612345678</code>)</li>
            <li><strong>SMS Number</strong>: your SMS-enabled number (optional, can be the same)</li>
          </ul>
        </li>
        <li>Click <strong>Save</strong> &mdash; Nero validates your credentials automatically</li>
      </ol>
    </div>

    <!-- Step 4 -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-3">
        <span class="step-number text-sm">4</span>
        <h3 class="!mt-0 !mb-0">Set up webhooks for incoming messages</h3>
      </div>
      <p>To receive incoming WhatsApp and SMS messages in Nero:</p>
      <ol>
        <li>In <strong>Twilio Console</strong> &rarr; <strong>Phone Numbers</strong> &rarr; <strong>Manage</strong> &rarr; <strong>Active Numbers</strong></li>
        <li>Click on your phone number</li>
        <li>Scroll to <strong>Messaging Configuration</strong></li>
        <li>Under "A message comes in", set:
          <ul>
            <li><strong>Webhook URL</strong>: <code>https://nerops.ai/api/webhooks/twilio</code></li>
            <li><strong>HTTP Method</strong>: POST</li>
          </ul>
        </li>
        <li>Click <strong>Save</strong></li>
      </ol>
      <p>For WhatsApp, the webhook is configured through your WhatsApp Sender settings in the same way.</p>
    </div>

    <!-- Pricing note -->
    <div class="card p-4 mb-6 bg-surface-alt/50">
      <p class="text-sm !mb-0 flex items-start gap-2">
        <svg class="w-4 h-4 text-text-tertiary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span><strong>Pricing:</strong> Twilio charges per message: ~$0.005/SMS, ~$0.005/WhatsApp message (conversation-based pricing). New accounts get trial credit.</span>
      </p>
    </div>
  </section>

  <hr />

  <!-- ===== FAQ ===== -->
  <section id="faq" data-animate>
    <h2>
      <span class="inline-flex items-center gap-2">
        <svg class="w-5 h-5 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Frequently Asked Questions
      </span>
    </h2>

    <div class="space-y-3">
      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-semibold text-text hover:text-primary transition select-none">
          Are my credentials safe?
          <svg class="w-4 h-4 text-text-tertiary group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
          Yes. Your API keys and tokens are encrypted with AES-256 before being stored. They are never visible in the app — only our secure server-side functions can decrypt them to send messages.
        </div>
      </details>

      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-semibold text-text hover:text-primary transition select-none">
          Can I connect both SendGrid and Twilio?
          <svg class="w-4 h-4 text-text-tertiary group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
          Yes! Each integration works independently. You can have email via SendGrid and WhatsApp/SMS via Twilio at the same time.
        </div>
      </details>

      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-semibold text-text hover:text-primary transition select-none">
          Can different workspaces have different integrations?
          <svg class="w-4 h-4 text-text-tertiary group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
          Yes. Each workspace has its own separate credentials and configuration. One workspace's integration has no access to another's.
        </div>
      </details>

      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-semibold text-text hover:text-primary transition select-none">
          What happens if I disconnect an integration?
          <svg class="w-4 h-4 text-text-tertiary group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
          Your existing conversation history stays intact. You just won't be able to send or receive new messages through that channel until you reconnect.
        </div>
      </details>

      <details class="card group">
        <summary class="flex items-center justify-between cursor-pointer px-5 py-4 text-sm font-semibold text-text hover:text-primary transition select-none">
          I'm not receiving incoming messages — what should I check?
          <svg class="w-4 h-4 text-text-tertiary group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-text-secondary leading-relaxed">
          <ul class="mt-1">
            <li>Verify your webhook URL is correct in Twilio/SendGrid settings</li>
            <li>Check that your DNS MX record is set up (for email)</li>
            <li>Make sure the integration is active (green checkmark) in Nero settings</li>
            <li>For Twilio: ensure the phone number has the webhook configured</li>
          </ul>
        </div>
      </details>
    </div>
  </section>

  <!-- Bottom navigation -->
  <div class="mt-16 pt-8 border-t border-border-subtle">
    <p class="text-sm text-text-tertiary">
      Need help? Reach out at <a href="mailto:support@nerops.ai">support@nerops.ai</a>
    </p>
  </div>
</DocsLayout>
