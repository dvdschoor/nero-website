---
/**
 * Alternating left-right feature showcase blocks with icons.
 * Used on the /features page for deep-dive feature descriptions.
 */
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

interface FeatureBlock {
  label: string;
  title: string;
  description: string;
  bullets: string[];
  icon: string;
  accentColor: string;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);

const features: FeatureBlock[] = lang === 'nl' ? [
