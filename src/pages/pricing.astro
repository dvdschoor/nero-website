---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/sections/CTA.astro';
import FAQ from '../components/sections/FAQ.astro';
import Footer from '../components/Footer.astro';

const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nerops.ai';

const plans = [
  {
    name: 'Starter',
    price: 'Free',
    period: '',
    description: 'For individuals and small teams getting started.',
    features: [
      'Up to 3 team members',
      'Task operations & unified inbox',
      'Contact & company management',
      'AI triage & prioritization (25/month)',
      'Email integration',
      '1 workspace',
    ],
    cta: 'Get started',
    href: `https://${appDomain}/login`,
    highlighted: false,
  },
  {
    name: 'Pro',
    price: '\u20AC19',
    period: '/user/month',
    description: 'For growing teams that need full AI and multi-channel.',
    features: [
      'Up to 10 team members',
      'Everything in Starter',
      'AI triage, drafts & daily briefings (200/day)',
      'Operational knowledge base',
      'Deal pipelines & forecasting',
      'Sprint planning & AI task suggestions',
      'Slack, WhatsApp & SMS integrations',
      'Email support',
    ],
    cta: 'Start free trial',
    href: `https://${appDomain}/login`,
    highlighted: true,
  },
  {
    name: 'Business',
    price: '\u20AC59',
    period: '/user/month',
    description: 'For teams that want AI to drive their operations.',
    features: [
      'Unlimited team members',
      'Everything in Pro',
      'AI campaigns & sequences (1,000/day)',
      'AI-personalized outreach per contact',
      'Custom AI procedures & workflows',
      'Unlimited workspaces',
      'Priority support',
    ],
    cta: 'Start free trial',
    href: `https://${appDomain}/login`,
    highlighted: false,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'For organizations with advanced needs.',
    features: [
      'Everything in Business',
      'Unlimited AI operations',
      'Custom integrations',
      'SSO & advanced security',
      'Dedicated account manager',
      'SLA guarantee',
      'Custom onboarding',
    ],
    cta: 'Contact us',
    href: 'mailto:hello@nerops.ai',
    highlighted: false,
  },
];
---

<BaseLayout title="Pricing | Nero" lang="en">
  <Navbar lang="en" />
  <main>
    <!-- Header -->
    <section class="pt-36 pb-16 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label mb-4">Pricing</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-text mt-4">
          Simple, transparent <span class="text-gradient">pricing</span>
        </h1>
        <p class="mt-5 text-lg text-text-secondary max-w-xl mx-auto">
          Start free, upgrade when you need more. No hidden fees, no surprises.
        </p>
      </div>
    </section>

    <!-- Plans -->
    <section class="pb-24 px-6">
      <div class="max-w-6xl mx-auto grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {plans.map((plan) => (
          <div class={`card p-7 flex flex-col ${
            plan.highlighted
              ? 'border-primary ring-1 ring-primary/20 relative'
              : ''
          }`}>
            {plan.highlighted && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                <span class="bg-primary text-white text-xs font-semibold px-3 py-1 rounded-full">
                  Most popular
                </span>
              </div>
            )}

            <h3 class="text-lg font-bold text-text">{plan.name}</h3>
            <div class="mt-3 flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-text">{plan.price}</span>
              {plan.period && (
                <span class="text-sm text-text-tertiary">{plan.period}</span>
              )}
            </div>
            <p class="mt-2 text-sm text-text-secondary">{plan.description}</p>

            <ul class="mt-6 space-y-3 flex-1">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                  <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href={plan.href}
              class={`btn btn-lg w-full mt-8 justify-center ${
                plan.highlighted ? 'btn-primary' : 'btn-secondary'
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))}
      </div>
    </section>

    <FAQ lang="en" />
    <CTA lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
