  {
    label: 'Projecten',
    title: 'Projecten met AI-geheugen',
    description: 'Meeting notes, actiepunten en klantsamenvattingen — AI verwerkt alles en houdt je team scherp.',
    bullets: [
      'Meeting notes met automatische AI-verwerking',
      'Actiepunten automatisch geextraheerd',
      'Klantsamenvatting per project',
      'Meeting-tijdlijn overzicht',
      'Alles gekoppeld aan je kennisbank',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />`,
    accentColor: 'bg-primary/10 text-primary',
  },
] : [
  {
    label: 'AI Operations',
    title: 'Your AI ops manager, always on',
    description: 'Nero learns your procedures, SLAs, and playbooks. It triages incoming work, suggests priorities, and briefs your team daily — like having a full-time ops manager.',
    bullets: [
      'Automatic triage based on your business procedures',
      'Daily AI briefing with focus areas and risk flags',
      'Draft replies crafted per communication channel',
      'Workflow suggestions with auto-generated subtasks',
      'Knowledge articles created from daily work context',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
    accentColor: 'bg-warning/10 text-warning',
  },
  {
    label: 'Inbox',
    title: 'Every channel, one command center',
    description: 'Email, Slack, WhatsApp, and phone — everything converges. AI knows which procedure applies and acts on your knowledge base.',
    bullets: [
      'AI triage categorizes based on your procedures',
      'Priority derived from your SLAs and business rules',
      'Swipe actions for quick archive and assign',
      'Paste any text and let AI create structured tasks',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z" />`,
    accentColor: 'bg-info/10 text-info',
  },
  {
    label: 'Task Ops',
    title: 'Work that organizes itself',
    description: 'AI assigns priorities, breaks down projects, and keeps your sprints on track. You decide, Nero handles the rest.',
    bullets: [
      'Standup view with AI-powered focus highlights',
      'Sprint planning with intelligent task suggestions',
      'Automatic urgency based on SLA and context',
      'Epics with AI-generated subtask breakdowns',
      'Bulk actions and swipe-to-assign',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    accentColor: 'bg-success/10 text-success',
  },
  {
    label: 'Knowledge',
    title: 'The brain behind your operation',
    description: 'Your procedures, playbooks, and SLAs — not as dead documents, but as active input for AI decisions.',
    bullets: [
      'Procedures and playbooks that AI uses for triage',
      'SLA descriptions that determine urgency levels',
      'AI generates new articles from daily work',
      'Searchable, categorized, always up to date',
      'Status workflow: draft, review, published',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />`,
    accentColor: 'bg-primary-400/10 text-primary-400',
  },
  {
    label: 'Relationships',
    title: 'Relationships with context',
    description: 'Contacts, companies, and deals — always enriched with the right context from your knowledge base and past interactions.',
    bullets: [
      'Company profiles with SLA tracking for AI prioritization',
      'Contacts with lead scoring and lifecycle stages',
      'Deal pipeline with weighted forecast',
      'Full activity history per relationship',
      'Multi-currency support (EUR, USD, GBP)',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />`,
    accentColor: 'bg-accent/10 text-accent',
  },
  {
    label: 'Outbound',
    title: 'AI-powered campaigns & sequences',
    description: 'Generate personalized outbound campaigns per channel and set up multi-step follow-up sequences — AI writes, you approve.',
    bullets: [
      'Campaigns via email, WhatsApp, Slack, or phone',
      'AI generates personalized messages per contact',
      'Multi-step sequences with automatic follow-ups',
      'Review flow: approve messages before they go out',
      'Per-campaign stats: sent, delivered, opened, replied',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46" />`,
    accentColor: 'bg-warning/10 text-warning',
  },
  {
    label: 'Projects',
    title: 'Projects with AI memory',
    description: 'Meeting notes, action items, and client summaries — AI processes everything and keeps your team sharp.',
    bullets: [
      'Meeting notes with automatic AI processing',
      'Action items extracted automatically',
      'Client summary per project',
      'Meeting timeline overview',
      'Everything linked to your knowledge base',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 9.776c.112-.017.227-.026.344-.026h15.812c.117 0 .232.009.344.026m-16.5 0a2.25 2.25 0 00-1.883 2.542l.857 6a2.25 2.25 0 002.227 1.932H19.05a2.25 2.25 0 002.227-1.932l.857-6a2.25 2.25 0 00-1.883-2.542m-16.5 0V6A2.25 2.25 0 016 3.75h3.879a1.5 1.5 0 011.06.44l2.122 2.12a1.5 1.5 0 001.06.44H18A2.25 2.25 0 0120.25 9v.776" />`,
    accentColor: 'bg-primary/10 text-primary',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto space-y-20">
    {features.map((feature, i) => (
      <div class={`flex flex-col ${i % 2 === 1 ? 'md:flex-row-reverse' : 'md:flex-row'} gap-12 items-center`} data-animate>
        <div class="flex-shrink-0">
          <div class={`w-20 h-20 rounded-2xl ${feature.accentColor} flex items-center justify-center`}>
            <svg class="w-9 h-9" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={feature.icon} />
            </svg>
          </div>
        </div>
        <div class="flex-1">
          <span class="section-label mb-3">{feature.label}</span>
          <h3 class="text-2xl md:text-3xl font-bold text-text mt-3">{feature.title}</h3>
          <p class="mt-3 text-text-secondary leading-relaxed">{feature.description}</p>
          <ul class="mt-5 space-y-2.5">
            {feature.bullets.map((bullet) => (
              <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                <svg class="w-4 h-4 text-primary mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>
</section>
