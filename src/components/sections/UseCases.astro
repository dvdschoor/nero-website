---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const isNl = lang === 'nl';

const cases = isNl ? [
  {
    title: 'Agencies & bureaus',
    description: 'Beheer meerdere klanten, SLA\'s en communicatiekanalen. Nero triageert inkomend werk per klant en houdt je team scherp met dagelijkse briefings.',
    bullets: ['Multi-client workflows', 'SLA-tracking per klant', 'AI-triage over alle kanalen'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />`,
    accent: 'bg-primary/10 text-primary',
  },
  {
    title: 'Startups & scale-ups',
    description: 'Geen tijd voor een volledige ops-afdeling? Nero vervangt spreadsheets, losse tools en handmatige coordinatie met een AI-gestuurd systeem.',
    bullets: ['Vervangt 3-5 losse tools', 'Van dag 1 operationeel', 'Schaalt mee met je team'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />`,
    accent: 'bg-accent/10 text-accent',
  },
  {
    title: 'Operations & service teams',
    description: 'Voor teams die dagelijks tientallen verzoeken verwerken. Nero leert je procedures en handelt op basis van je kennisbank, consequent en snel.',
    bullets: ['Procedure-gedreven triage', 'Automatische prioritering', 'Kennisbank als beslisboom'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.1-5.1m0 0L3.13 13.26l2.72 2.72m.47-5.91l4.24-4.24m4.24 4.24l5.1 5.1m0 0l3.19-3.19-2.72-2.72m-.47 5.91l-4.24 4.24M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    accent: 'bg-success/10 text-success',
  },
] : [
  {
    title: 'Agencies & consultancies',
    description: 'Manage multiple clients, SLAs, and communication channels. Nero triages incoming work per client and keeps your team sharp with daily briefings.',
    bullets: ['Multi-client workflows', 'SLA tracking per client', 'AI triage across all channels'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />`,
    accent: 'bg-primary/10 text-primary',
  },
  {
    title: 'Startups & scale-ups',
    description: 'No budget for a full ops department? Nero replaces spreadsheets, scattered tools, and manual coordination with one AI-driven system.',
    bullets: ['Replaces 3-5 separate tools', 'Operational from day one', 'Scales with your team'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.581-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />`,
    accent: 'bg-accent/10 text-accent',
  },
  {
    title: 'Operations & service teams',
    description: 'For teams processing dozens of requests daily. Nero learns your procedures and acts on your knowledge base, consistently and fast.',
    bullets: ['Procedure-driven triage', 'Automatic prioritization', 'Knowledge base as decision tree'],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.42 15.17l-5.1-5.1m0 0L3.13 13.26l2.72 2.72m.47-5.91l4.24-4.24m4.24 4.24l5.1 5.1m0 0l3.19-3.19-2.72-2.72m-.47 5.91l-4.24 4.24M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    accent: 'bg-success/10 text-success',
  },
];
---

<section class="py-24 px-6 bg-surface-alt/50">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-16" data-animate>
      <span class="section-label mb-4">
        {isNl ? 'Voor wie' : 'Who it\'s for'}
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mt-4">
        {isNl ? 'Gebouwd voor teams die' : 'Built for teams that'}
        <span class="text-gradient">{isNl ? ' resultaat leveren' : ' deliver results'}</span>
      </h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        {isNl
          ? 'Of je nu een bureau, startup of operations team runt, Nero past zich aan jouw werkwijze aan.'
          : 'Whether you run an agency, a startup, or an operations team, Nero adapts to your way of working.'}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {cases.map((c, i) => (
        <div class="card card-hover p-6 cursor-pointer" data-animate style={`transition-delay: ${i * 100}ms`}>
          <div class={`w-12 h-12 rounded-xl ${c.accent} flex items-center justify-center mb-5`}>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={c.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">{c.title}</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">{c.description}</p>
          <ul class="mt-4 space-y-2">
            {c.bullets.map((bullet) => (
              <li class="flex items-center gap-2 text-sm text-text-secondary">
                <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
