---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import CTA from '../components/sections/CTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Security — Nero" lang="en">
  <Navbar lang="en" />
  <main>
    <!-- Header -->
    <section class="pt-36 pb-16 px-6">
      <div class="max-w-3xl mx-auto text-center">
        <span class="section-label mb-4">Security</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-text mt-4">
          Enterprise-grade <span class="text-gradient">security by default</span>
        </h1>
        <p class="mt-5 text-lg text-text-secondary max-w-2xl mx-auto leading-relaxed">
          Every integration is encrypted, every request is verified, and every organization is fully isolated. Security isn't an add-on — it's how Nero is built.
        </p>
      </div>
    </section>

    <!-- Security features grid -->
    <section class="py-20 px-6">
      <div class="max-w-5xl mx-auto grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="card card-hover p-6" data-animate>
          <div class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Encrypted Credentials</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            All API keys and tokens are encrypted at rest. Credentials are only decrypted in memory during execution — never stored in plain text, never logged.
          </p>
        </div>

        <div class="card card-hover p-6" data-animate style="transition-delay: 80ms">
          <div class="w-12 h-12 rounded-xl bg-success/10 text-success flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Database-Level Access Control</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Access control is enforced at the database level, not just in the application. Users can only access data within their own organization — no exceptions.
          </p>
        </div>

        <div class="card card-hover p-6" data-animate style="transition-delay: 160ms">
          <div class="w-12 h-12 rounded-xl bg-warning/10 text-warning flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Webhook Signature Verification</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Every incoming webhook is cryptographically verified before processing. Requests that fail signature validation are rejected — no data is written.
          </p>
        </div>

        <div class="card card-hover p-6" data-animate style="transition-delay: 240ms">
          <div class="w-12 h-12 rounded-xl bg-info/10 text-info flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Replay Attack Protection</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Timestamp validation on all integration requests prevents replay attacks. Requests outside the tolerance window are automatically rejected.
          </p>
        </div>

        <div class="card card-hover p-6" data-animate style="transition-delay: 320ms">
          <div class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Organization Isolation</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Each organization's data is fully isolated. Credentials, contacts, messages, and knowledge are scoped — cross-organization access is impossible.
          </p>
        </div>

        <div class="card card-hover p-6" data-animate style="transition-delay: 400ms">
          <div class="w-12 h-12 rounded-xl bg-error/10 text-error flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m0-10.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.75c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.57-.598-3.75h-.152c-3.196 0-6.1-1.249-8.25-3.286zm0 13.036h.008v.008H12v-.008z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-text">Token-Authenticated Inbound</h3>
          <p class="mt-2 text-sm text-text-secondary leading-relaxed">
            Inbound email and messaging webhooks require a unique authentication token per organization. Unauthorized requests are rejected before any processing occurs.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-20 px-6 bg-surface-alt/50">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14" data-animate>
          <span class="section-label mb-4">How it works</span>
          <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
            Security at <span class="text-gradient">every step</span>
          </h2>
        </div>

        <div class="space-y-6">
          <div class="card p-6" data-animate>
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-sm font-bold">1</span>
              </div>
              <div>
                <h3 class="font-bold text-text">Connect with confidence</h3>
                <p class="mt-1 text-sm text-text-secondary">When you connect an integration, your credentials are immediately encrypted and stored securely. They're never visible again — not even to you.</p>
              </div>
            </div>
          </div>

          <div class="card p-6" data-animate style="transition-delay: 100ms">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-sm font-bold">2</span>
              </div>
              <div>
                <h3 class="font-bold text-text">Verified at every entry point</h3>
                <p class="mt-1 text-sm text-text-secondary">Every incoming message — whether email, WhatsApp, SMS, or Slack — is cryptographically verified before it enters Nero. Forged or tampered requests are dropped.</p>
              </div>
            </div>
          </div>

          <div class="card p-6" data-animate style="transition-delay: 200ms">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-sm font-bold">3</span>
              </div>
              <div>
                <h3 class="font-bold text-text">Isolated by design</h3>
                <p class="mt-1 text-sm text-text-secondary">Your data never mixes with other organizations. Access control is enforced at the infrastructure level — not just in code, but in how data is stored and queried.</p>
              </div>
            </div>
          </div>

          <div class="card p-6" data-animate style="transition-delay: 300ms">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 rounded-lg bg-primary/10 text-primary flex items-center justify-center flex-shrink-0 mt-0.5">
                <span class="text-sm font-bold">4</span>
              </div>
              <div>
                <h3 class="font-bold text-text">Authenticated every request</h3>
                <p class="mt-1 text-sm text-text-secondary">Every API call is authenticated and authorized against the user's identity and organization. No anonymous access, no shared tokens, no shortcuts.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust bar -->
    <section class="py-16 px-6 border-t border-border-subtle">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center" data-animate>
          <div>
            <div class="text-2xl font-extrabold text-gradient">Encrypted</div>
            <div class="mt-1 text-xs text-text-tertiary">Credentials at rest</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-gradient">Verified</div>
            <div class="mt-1 text-xs text-text-tertiary">Every webhook</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-gradient">Isolated</div>
            <div class="mt-1 text-xs text-text-tertiary">Per organization</div>
          </div>
          <div>
            <div class="text-2xl font-extrabold text-gradient">Zero</div>
            <div class="mt-1 text-xs text-text-tertiary">Plain-text secrets</div>
          </div>
        </div>
      </div>
    </section>

    <CTA lang="en" />
  </main>
  <Footer lang="en" />
</BaseLayout>
