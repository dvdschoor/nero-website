---
import type { Lang } from '../../i18n/translations';
import { useTranslations } from '../../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nerops.ai';
---

<section class="relative pt-28 pb-8 px-6 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 -z-10 bg-gradient-mesh">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[600px] bg-primary-100/30 rounded-full blur-[100px]"></div>
    <div class="absolute top-40 right-1/4 w-[400px] h-[400px] bg-accent/[0.04] rounded-full blur-[80px]"></div>
  </div>

  <div class="max-w-4xl mx-auto text-center">
    <!-- Badge -->
    <div class="animate-reveal">
      <div class="section-label mb-8 inline-flex">
        <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse-glow"></span>
        {t.heroBadge}
      </div>
    </div>

    <!-- Headline -->
    <h1 class="animate-reveal delay-100 text-5xl md:text-6xl lg:text-7xl font-extrabold text-text leading-[1.08]">
      {t.heroTitle}<br />
      <span class="text-gradient">{t.heroTitleAccent}</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-reveal delay-200 mt-6 text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
      {t.heroSubtitle}
    </p>

    <!-- CTAs -->
    <div class="animate-reveal delay-300 mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href={`https://${appDomain}/login`} class="btn btn-primary btn-lg w-full sm:w-auto">
        {t.heroCta}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#features" class="btn btn-secondary btn-lg w-full sm:w-auto">
        {t.heroCtaSecondary}
      </a>
    </div>

    <!-- Social proof -->
    <div class="animate-reveal delay-400 mt-14 flex items-center justify-center gap-3 text-text-tertiary text-sm">
      <div class="flex -space-x-2.5">
        {['bg-primary-300', 'bg-accent-light/40', 'bg-primary-200', 'bg-primary-400/40', 'bg-accent/20'].map((bg, i) => (
          <div class={`w-8 h-8 rounded-full border-2 border-bg ${bg} flex items-center justify-center`}>
            <span class="text-[10px] font-bold text-primary-900">
              {['DV', 'MK', 'JL', 'RS', 'AB'][i]}
            </span>
          </div>
        ))}
      </div>
      <span>{t.socialProofTitle}</span>
    </div>
  </div>

  <!-- App preview mockup -->
  <div class="animate-reveal delay-500 mt-16 max-w-5xl mx-auto">
    <div class="relative">
      <div class="rounded-xl overflow-hidden border border-border shadow-[0_8px_60px_-12px_rgba(79,70,229,0.15)]">
        <!-- Browser title bar -->
        <div class="bg-surface-alt border-b border-border-subtle px-4 py-3 flex items-center gap-3">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-400/60"></div>
            <div class="w-3 h-3 rounded-full bg-green-400/60"></div>
          </div>
          <div class="flex-1 flex justify-center">
            <div class="bg-bg rounded-md px-4 py-1 text-xs text-text-tertiary font-medium flex items-center gap-2">
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
              </svg>
              app.nerops.ai
            </div>
          </div>
          <div class="w-16"></div>
        </div>

        <!-- App content -->
        <div class="bg-bg p-4 md:p-6">
          <div class="flex gap-4 md:gap-6">
            <!-- Sidebar -->
            <div class="hidden md:block w-52 flex-shrink-0">
              <div class="space-y-1">
                {['Dashboard', 'Inbox', 'Tasks', 'Contacts', 'Deals', 'Knowledge'].map((item, i) => (
                  <div class={`flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm ${
                    i === 0 ? 'bg-primary/8 text-primary font-semibold' : 'text-text-secondary'
                  }`}>
                    <div class={`w-4 h-4 rounded ${i === 0 ? 'bg-primary/20' : 'bg-text-tertiary/20'}`}></div>
                    {item}
                  </div>
                ))}
              </div>
            </div>

            <!-- Main -->
            <div class="flex-1 min-w-0">
              <div class="mb-4">
                <div class="h-6 w-48 bg-text/8 rounded-md mb-2"></div>
                <div class="h-4 w-72 bg-text-tertiary/10 rounded"></div>
              </div>
              <div class="grid grid-cols-3 gap-3 mb-4">
                {[
                  { label: 'Urgent', value: '3', color: 'text-error' },
                  { label: 'In progress', value: '12', color: 'text-warning' },
                  { label: 'Closing', value: '5', color: 'text-success' },
                ].map((m) => (
                  <div class="card p-3">
                    <div class={`text-xl font-bold ${m.color}`}>{m.value}</div>
                    <div class="text-xs text-text-tertiary mt-0.5">{m.label}</div>
                  </div>
                ))}
              </div>
              <div class="card divide-y divide-border-subtle">
                {[
                  { title: 'Review Q1 proposal', tag: 'High', tc: 'bg-error/10 text-error' },
                  { title: 'Follow up with Acme Corp', tag: 'Medium', tc: 'bg-warning/10 text-warning' },
                  { title: 'Update knowledge article', tag: 'Low', tc: 'bg-success/10 text-success' },
                ].map((task) => (
                  <div class="flex items-center gap-3 px-4 py-3">
                    <div class="w-4 h-4 rounded border-2 border-border flex-shrink-0"></div>
                    <span class="text-sm text-text flex-1 truncate">{task.title}</span>
                    <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${task.tc}`}>{task.tag}</span>
                  </div>
                ))}
              </div>
            </div>

            <!-- AI sidebar -->
            <div class="hidden lg:block w-56 flex-shrink-0">
              <div class="card p-4">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-5 h-5 rounded-md bg-primary/10 flex items-center justify-center">
                    <svg class="w-3 h-3 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                    </svg>
                  </div>
                  <span class="text-xs font-semibold text-text">AI Briefing</span>
                </div>
                <div class="space-y-2">
                  <div class="h-3 w-full bg-primary/6 rounded"></div>
                  <div class="h-3 w-4/5 bg-primary/6 rounded"></div>
                  <div class="h-3 w-3/5 bg-primary/6 rounded"></div>
                </div>
                <div class="mt-3 pt-3 border-t border-border-subtle">
                  <div class="text-[10px] font-medium text-primary">2 action items</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      <!-- Glow -->
      <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-3/4 h-16 bg-primary/8 rounded-full blur-2xl"></div>
    </div>
  </div>
</section>
