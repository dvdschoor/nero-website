---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

interface FeatureBlock {
  label: string;
  title: string;
  description: string;
  bullets: string[];
  icon: string;
  accentColor: string;
}

const { lang = 'en' } = Astro.props;

const features: FeatureBlock[] = lang === 'nl' ? [
  {
    label: 'AI Operations',
    title: 'Je AI ops manager, altijd aan',
    description: 'Nero leert je procedures, SLA\'s en werkwijzen. Het triageert inkomend werk, stelt prioriteiten voor en brieft je team dagelijks — alsof je een fulltime ops manager hebt.',
    bullets: [
      'Automatische triage op basis van je bedrijfsprocedures',
      'Dagelijkse AI-briefing met focuspunten en risico\'s',
      'Concept-antwoorden opgesteld per communicatiekanaal',
      'Workflow-suggesties met automatisch gegenereerde subtaken',
      'Kennisartikelen automatisch aangemaakt uit context',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
    accentColor: 'bg-warning/10 text-warning',
  },
  {
    label: 'Inbox',
    title: 'Elk kanaal, een commandocentrum',
    description: 'E-mail, Slack, WhatsApp en telefoon — alles komt samen. AI weet welke procedure van toepassing is en handelt op basis van je kennisbank.',
