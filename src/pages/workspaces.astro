---
import BaseLayout from '../layouts/BaseLayout.astro';
import { createSupabaseClient } from '../lib/supabase';
import { useTranslations } from '../i18n/utils';

const t = useTranslations('en');
const { client, isAuthenticated } = createSupabaseClient(Astro.cookies);

if (!isAuthenticated) {
  return Astro.redirect('/');
}

const { data: { user } } = await client.auth.getUser();

if (!user) {
  return Astro.redirect('/');
}

const { data: profile } = await client
  .from('profiles')
  .select('display_name, avatar_url')
  .eq('id', user.id)
  .single();

const { data: memberships } = await client
  .from('org_members')
  .select('role, organizations(id, name, slug, logo_url)')
  .eq('user_id', user.id);

const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nerops.ai';
const displayName = profile?.display_name || user.email?.split('@')[0] || 'there';
---

<BaseLayout title={`${t.workspacesTitle} | Nero`} lang="en">
  <div class="min-h-screen bg-bg flex flex-col">
    <!-- Header -->
    <header class="bg-gradient-to-br from-primary via-primary-800 to-primary-950 text-white py-14 px-6">
      <div class="max-w-2xl mx-auto text-center">
        <a href="/" class="inline-flex items-center gap-2 mb-8">
          <img src="/nero-logo.png" alt="Nero" class="w-8 h-8 rounded-lg" />
          <span class="text-xl font-bold text-white">nero</span>
        </a>
        <h1 class="text-4xl md:text-5xl font-bold">
          {t.workspacesTitle}, {displayName}
        </h1>
        <p class="mt-3 text-primary-200 text-lg">{t.workspacesSubtitle}</p>
      </div>
    </header>

    <!-- Workspace list -->
    <main class="flex-1 px-6 py-12">
      <div class="max-w-xl mx-auto">
        <h2 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-4">
          {t.workspacesYourWorkspaces}
        </h2>

        <div class="card divide-y divide-border-subtle overflow-hidden">
          {memberships && memberships.length > 0 ? (
            memberships.map((membership: any) => {
              const org = membership.organizations;
              const initial = org.name?.charAt(0)?.toUpperCase() || '?';
              const href = `https://${org.slug}.${appDomain}`;

              return (
                <a
                  href={href}
                  class="flex items-center gap-4 p-4 hover:bg-bg transition group"
                >
                  {org.logo_url ? (
                    <img
                      src={org.logo_url}
                      alt={org.name}
                      class="w-12 h-12 rounded-xl object-cover"
                    />
                  ) : (
                    <div class="w-12 h-12 rounded-xl bg-primary text-white flex items-center justify-center font-bold text-lg">
                      {initial}
                    </div>
                  )}

                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-text">{org.name}</div>
                    <div class="text-sm text-text-secondary capitalize">{membership.role}</div>
                  </div>

                  <svg
                    class="w-5 h-5 text-text-tertiary group-hover:text-text-secondary transition"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              );
            })
          ) : (
            <div class="p-8 text-center text-text-tertiary">
              <p>No workspaces found.</p>
            </div>
          )}
        </div>

        <div class="mt-6 text-center">
          <a
            href={`https://${appDomain}/login`}
            class="text-sm font-semibold text-primary hover:text-primary-700 transition"
          >
            {t.workspacesCreate}
          </a>
        </div>

        <div class="mt-8 text-center">
          <a
            href="/api/auth/signout"
            class="text-sm text-text-tertiary hover:text-text-secondary transition"
          >
            {t.workspacesDifferentAccount}
          </a>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
