    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 13.5h3.86a2.25 2.25 0 012.012 1.244l.256.512a2.25 2.25 0 002.013 1.244h3.218a2.25 2.25 0 002.013-1.244l.256-.512a2.25 2.25 0 012.013-1.244h3.859m-19.5.338V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18v-4.162c0-.224-.034-.447-.1-.661L19.24 5.338a2.25 2.25 0 00-2.15-1.588H6.911a2.25 2.25 0 00-2.15 1.588L2.35 13.177a2.25 2.25 0 00-.1.661z" />`,
    accentColor: 'bg-info/10 text-info',
  },
  {
    label: 'Task Ops',
    title: 'Werk dat zichzelf organiseert',
    description: 'AI wijst prioriteiten toe, breekt werk op en houdt je sprints op koers. Jij beslist, Nero regelt de rest.',
    bullets: [
      'Standup-weergave met AI-aangedreven focuspunten',
      'Sprint planning met intelligente taaksuggesties',
      'Automatische urgentie op basis van SLA en context',
      'Epics met AI-gegenereerde subtaken',
      'Bulk-acties en toewijzing via swipe',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    accentColor: 'bg-success/10 text-success',
  },
  {
    label: 'Kennisbank',
    title: 'Het brein achter je operatie',
    description: 'Je procedures, playbooks en SLA\'s — niet als dode documenten, maar als actieve input voor AI-beslissingen.',
    bullets: [
      'Procedures en playbooks die AI gebruikt voor triage',
      'SLA-beschrijvingen die urgentie bepalen',
      'AI genereert nieuwe artikelen uit dagelijks werk',
      'Doorzoekbaar, gecategoriseerd, altijd up-to-date',
      'Status workflow: concept, review, gepubliceerd',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />`,
    accentColor: 'bg-primary-400/10 text-primary-400',
  },
  {
    label: 'Relaties',
    title: 'Relaties met context',
    description: 'Contacten, bedrijven en deals — altijd met de juiste context uit je kennisbank en eerdere interacties.',
    bullets: [
      'Bedrijfsprofielen met SLA-tracking voor AI-prioritering',
      'Contacten met leadscore en lifecycle-status',
      'Deal-pipeline met gewogen forecast',
      'Volledige activiteitenhistorie per relatie',
      'Multi-valuta ondersteuning (EUR, USD, GBP)',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />`,
    accentColor: 'bg-accent/10 text-accent',
  },
  {
    label: 'Outbound',
    title: 'AI-gestuurde campagnes & sequences',
    description: 'Genereer gepersonaliseerde outbound-campagnes per kanaal en stel meerstaps follow-up sequences in — AI schrijft, jij keurt goed.',
    bullets: [
      'Campagnes via e-mail, WhatsApp, Slack of telefoon',
      'AI genereert gepersonaliseerde berichten per contact',
      'Meerstaps sequences met automatische follow-ups',
      'Review-flow: beoordeel en keur berichten goed voor verzending',
      'Statistieken per campagne: verzonden, geopend, beantwoord',
    ],
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 110-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38c-.551.318-1.26.117-1.527-.461a20.845 20.845 0 01-1.44-4.282m3.102.069a18.03 18.03 0 01-.59-4.59c0-1.586.205-3.124.59-4.59m0 9.18a23.848 23.848 0 018.835 2.535M10.34 6.66a23.847 23.847 0 008.835-2.535m0 0A23.74 23.74 0 0018.795 3m.38 1.125a23.91 23.91 0 011.014 5.395m-1.014 8.855c-.118.38-.245.754-.38 1.125m.38-1.125a23.91 23.91 0 001.014-5.395m0-3.46c.495.413.811 1.035.811 1.73 0 .695-.316 1.317-.811 1.73m0-3.46a24.347 24.347 0 010 3.46" />`,
