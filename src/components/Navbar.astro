---
import type { Lang } from '../i18n/translations';
import { useTranslations, getLocalizedPath, getAlternateLang } from '../i18n/utils';
import { languages } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const t = useTranslations(lang);
const altLang = getAlternateLang(lang);
const appDomain = import.meta.env.PUBLIC_APP_DOMAIN || 'nerops.ai';
---

<nav id="navbar" class="fixed top-0 w-full z-50 glass border-b border-border-subtle transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 group">
      <img src="/nero-logo.png" alt="Nero" class="w-8 h-8 rounded-lg group-hover:scale-105 transition-transform" />
      <span class="text-xl font-bold text-text">nero</span>
    </a>

    <!-- Center nav (desktop) -->
    <div class="hidden md:flex items-center gap-8">
      <a href={getLocalizedPath('/features', lang)} class="text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navFeatures}
      </a>
      <a href={getLocalizedPath('/pricing', lang)} class="text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navPricing}
      </a>
    </div>

    <!-- Right side -->
    <div class="flex items-center gap-3">
      <!-- Language switcher -->
      <a
        href={getLocalizedPath(Astro.url.pathname.replace(`/${lang}`, '') || '/', altLang)}
        class="text-xs font-medium text-text-tertiary hover:text-text-secondary transition px-2 py-1 rounded-md hover:bg-surface-alt hidden sm:block"
      >
        {languages[altLang]}
      </a>

      <div class="w-px h-5 bg-border-subtle hidden sm:block"></div>

      <a
        href={`https://app.${appDomain}/auth/login`}
        class="text-sm font-medium text-text-secondary hover:text-text transition hidden md:block"
      >
        {t.navSignIn}
      </a>
      <a
        href={`https://app.${appDomain}/auth/signup`}
        class="btn btn-primary text-sm !py-2 !px-4 hidden sm:inline-flex"
      >
        {t.navGetStarted}
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 -mr-2 text-text-secondary hover:text-text transition"
        aria-label="Menu"
      >
        <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-border-subtle bg-surface">
    <div class="px-6 py-4 space-y-1">
      <a href={getLocalizedPath('/features', lang)} class="block py-2.5 text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navFeatures}
      </a>
      <a href={getLocalizedPath('/pricing', lang)} class="block py-2.5 text-sm font-medium text-text-secondary hover:text-text transition">
        {t.navPricing}
      </a>
      <div class="pt-3 border-t border-border-subtle mt-3 flex flex-col gap-2">
        <a href={`https://app.${appDomain}/auth/login`} class="btn btn-secondary w-full justify-center text-sm">
          {t.navSignIn}
        </a>
        <a href={`https://app.${appDomain}/auth/signup`} class="btn btn-primary w-full justify-center text-sm">
          {t.navGetStarted}
        </a>
      </div>
      <div class="pt-3">
        <a
          href={getLocalizedPath(Astro.url.pathname.replace(`/${lang}`, '') || '/', altLang)}
          class="text-xs font-medium text-text-tertiary hover:text-text-secondary transition"
        >
          {languages[altLang]}
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    menuIcon?.classList.toggle('hidden', open);
    closeIcon?.classList.toggle('hidden', !open);
  });
</script>
