---
import type { Lang } from '../../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const isNl = lang === 'nl';

const rows = isNl ? [
  { task: 'Inkomend werk beoordelen', without: 'Handmatig lezen, labelen, toewijzen', with: 'AI triageert op basis van je procedures' },
  { task: 'Prioriteiten bepalen', without: 'Onderbuikgevoel of spreadsheets', with: 'Automatisch op basis van SLA\'s en context' },
  { task: 'Team op de hoogte houden', without: 'Standup meetings, Slack-berichten', with: 'Dagelijkse AI-briefing met focuspunten' },
  { task: 'Antwoorden opstellen', without: 'Elke e-mail zelf schrijven', with: 'AI-concepten per kanaal, klaar om te versturen' },
  { task: 'Kennis bijhouden', without: 'Wiki\'s die niemand leest', with: 'Levende kennisbank die AI activeert' },
  { task: 'Taken aanmaken', without: 'Kopiëren, plakken, handmatig invullen', with: 'AI genereert taken met subtaken uit context' },
  { task: 'Outbound campagnes', without: 'Handmatig mailen, een-voor-een', with: 'AI genereert gepersonaliseerde berichten per contact' },
] : [
  { task: 'Reviewing incoming work', without: 'Manually read, label, assign', with: 'AI triages based on your procedures' },
  { task: 'Setting priorities', without: 'Gut feeling or spreadsheets', with: 'Automatic based on SLAs and context' },
  { task: 'Keeping the team informed', without: 'Standup meetings, Slack messages', with: 'Daily AI briefing with focus areas' },
  { task: 'Drafting replies', without: 'Write every email yourself', with: 'AI drafts per channel, ready to send' },
  { task: 'Maintaining knowledge', without: 'Wikis nobody reads', with: 'Living knowledge base that powers AI' },
  { task: 'Creating tasks', without: 'Copy, paste, fill in manually', with: 'AI generates tasks with subtasks from context' },
  { task: 'Outbound campaigns', without: 'Manual emails, one by one', with: 'AI generates personalized messages per contact' },
];
---

<section class="py-24 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12" data-animate>
      <span class="section-label mb-4">
        {isNl ? 'Vergelijk' : 'Compare'}
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-text mt-4">
        {isNl ? 'Handmatig vs. ' : 'Manual ops vs. '}
        <span class="text-gradient">Nero</span>
      </h2>
    </div>

    <!-- Desktop table -->
    <div class="card overflow-hidden hidden md:block" data-animate>
      <!-- Header -->
      <div class="grid grid-cols-[1.5fr_1fr_1fr] bg-surface-alt/80 border-b border-border-subtle">
        <div class="px-5 py-3 text-xs font-semibold text-text-tertiary uppercase tracking-wider">
          {isNl ? 'Taak' : 'Task'}
        </div>
        <div class="px-5 py-3 text-xs font-semibold text-error/80 uppercase tracking-wider text-center">
          {isNl ? 'Zonder Nero' : 'Without Nero'}
        </div>
        <div class="px-5 py-3 text-xs font-semibold text-primary uppercase tracking-wider text-center">
          {isNl ? 'Met Nero' : 'With Nero'}
        </div>
      </div>

      <!-- Rows -->
      {rows.map((row, i) => (
        <div class={`grid grid-cols-[1.5fr_1fr_1fr] ${i < rows.length - 1 ? 'border-b border-border-subtle' : ''}`}>
          <div class="px-5 py-4 text-sm font-medium text-text">
            {row.task}
          </div>
          <div class="px-5 py-4 text-sm text-text-tertiary text-center flex items-center justify-center gap-1.5">
            <svg class="w-4 h-4 text-error/50 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            <span>{row.without}</span>
          </div>
          <div class="px-5 py-4 text-sm text-text-secondary text-center flex items-center justify-center gap-1.5">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span>{row.with}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile cards -->
    <div class="md:hidden space-y-3">
      {rows.map((row, i) => (
        <div class="card p-4" data-animate style={`transition-delay: ${i * 60}ms`}>
          <h4 class="font-semibold text-text text-sm mb-3">{row.task}</h4>
          <div class="space-y-2">
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-error/60 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span class="text-xs text-text-tertiary">{row.without}</span>
            </div>
            <div class="flex items-start gap-2">
              <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span class="text-xs text-text-secondary">{row.with}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
